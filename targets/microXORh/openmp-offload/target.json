{
    "app": "microxorh",
    "model": "openmp-offload",
    "path": "targets/microXORh/openmp-offload/repo",
    "dependencies": ["llvm", "cuda"],
    "build_commands_debug": "make SM_VERSION=sm_80 DEBUG=yes CXX_COMPILER=clang++",
    "build_commands_perf": "make SM_VERSION=sm_80 CXX_COMPILER=clang++",
    "build_timeout": 30,
    "exe_file": "microXORh.exe",
    "debug_type": "match",
    "run_commands_debug": [
        "./microXORh.exe 4 2",
        "./microXORh.exe 1024 32",
        "./microXORh.exe 4096 16"
    ],
    "debug_outputs": [
        "Validation passed.",
        "Validation passed.",
        "Validation passed."
    ],
    "run_commands_perf": [
        "./microXORh.exe 4096 16"
    ],
    "perf_outputs": [
        "Validation passed."
    ],
    "run_timeout": 60,
    "ex_build_cmd": "make SM_VERSION=sm_80 CXX_COMPILER=clang++",
    "ex_build_desc": "a system with an NVIDIA GPU with compute capability 80 compiled with clang++",
    "build_filename": "Makefile",
    "ex_run_cmd": "./microXORh.exe 1024 32",
    "ex_run_desc": "a 1024 by 1024 input matrix and a kernel with 32 times 32 threads per block",
    "main_filename": "src/main.cpp",
    "filename_desc": "C++"
}
