{
    "app": "xsbench",
    "model": "cuda",
    "path": "targets/XSBench/cuda/repo",
    "dependencies": ["cuda"],
    "build_commands_debug": "make SM_VERSION=80 DEBUG=yes -j8",
    "build_commands_perf": "make SM_VERSION=80 -j8",
    "build_timeout": 30,
    "exe_file": "XSBench",
    "debug_type": "match",
    "run_commands_debug": [
        "./XSBench -m event -s small",
        "./XSBench -m event -s large"
    ],
    "debug_outputs": [
        "(Valid)",
        "(Valid)"
    ],
    "run_commands_perf": [
        "./XSBench -m event -s large"
    ],
    "perf_outputs": [
        "(Valid)"
    ],
    "run_timeout": 120
}
