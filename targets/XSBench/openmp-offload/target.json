{
    "app": "xsbench",
    "model": "openmp-offload",
    "path": "targets/XSBench/openmp-offload/repo",
    "dependencies": ["cuda", "llvm"],
    "build_commands_debug": "make CUDA_ARCH=80 DEBUG=yes -j8",
    "build_commands_perf": "make CUDA_ARCH=80 -j8",
    "build_timeout": 30,
    "exe_file": "XSBench",
    "debug_type": "match",
    "run_commands_debug": [
        "./XSBench -m event -s small",
        "./XSBench -m event -s large"
    ],
    "debug_outputs": [
        "(Valid)",
        "(Valid)"
    ],
    "run_commands_perf": [
        "./XSBench -m event -s large"
    ],
    "perf_outputs": [
        "(Valid)"
    ],
    "run_timeout": 120,
    "ex_build_cmd": "make CUDA_ARCH=80 COMPILER=llvm",
    "ex_build_desc": "a system with an NVIDIA GPU with compute capability 80 compiler with the clang++ compiler",
    "build_filename": "Makefile",
    "ex_run_cmd": "./XSBench -m event -s large",
    "ex_run_desc": "an event-based simulation with the large input size",
    "main_filename": "Main.c",
    "filename_desc": "C"
}
