{
    "app": "simplemoc-kernel",
    "model": "cuda",
    "path": "targets/SimpleMOC-kernel/cuda/repo",
    "dependencies": ["cuda"],
    "build_commands_debug": "cd include/ && make SM_VERSION=80 CFLAGS=-L/opt/nvidia/hpc_sdk/Linux_x86_64/23.9/math_libs/12.2/targets/x86_64-linux/lib/ DEBUG=yes",
    "build_commands_perf": "cd include/ && make SM_VERSION=80 CFLAGS=-L/opt/nvidia/hpc_sdk/Linux_x86_64/23.9/math_libs/12.2/targets/x86_64-linux/lib/",
    "build_timeout": 30,
    "exe_file": "include/SimpleMOC-kernel",
    "debug_type": "match",
    "run_commands_debug": [
        "include/SimpleMOC-kernel"
    ],
    "debug_outputs": [
        "Simulation Complete."
    ],
    "run_commands_perf": [
        "include/SimpleMOC-kernel"
    ],
    "perf_outputs": [
        "Simulation Complete."
    ],
    "run_timeout": 120
}
