{
    "app": "llm.c",
    "model": "kokkos",
    "path": "targets/llm.c/kokkos/repo",
    "dependencies": ["gnu", "cuda", "kokkos", "ninja"],
    "setup_commands": ["cp $SCRATCH/llmc_inputs/*.bin ."],
    "build_commands_debug": "cmake -DKOKKOS_BACKEND=CUDA -DCMAKE_CXX_COMPILER=g++ -GNinja -Bbuild . && cmake --build build/",
    "build_commands_perf": "cmake -DKOKKOS_BACKEND=CUDA -DCMAKE_CXX_COMPILER=g++ -GNinja -Bbuild . && cmake --build build/",
    "build_timeout": 120,
    "exe_file": "build/test_gpt2fp32cu",
    "debug_type": "match",
    "run_commands_debug": [
        "./build/test_gpt2fp32cu"
    ],
    "debug_outputs": [
        "overall okay: 1"
    ],
    "run_commands_perf": [
        "./build/test_gpt2fp32cu"
    ],
    "perf_outputs": [
        "overall okay: 1"
    ],
    "run_timeout": 120,
    "ex_build_cmd": "cmake -DKOKKOS_BACKEND=CUDA -DCMAKE_CXX_COMPILER=g++ -Bbuild . && cmake --build build/",
    "ex_build_desc": "the GPT-2 model test with FP32 precision to run with the Kokkos CUDA backend on an NVIDIA GPU compiled with g++ as the host compiler, with Kokkos installed and available in the environment through $PATH and $LD_LIBRARY_PATH",
    "build_filename": "CMakeLists.txt",
    "ex_run_cmd": "./build/test_gpt2fp32cu",
    "ex_run_desc": "a test run of the GPT-2 model with FP32 precision on an NVIDIA GPU",
    "main_filename": "test_gpt2_fp32.cpp",
    "filename_desc": "C++"
}
