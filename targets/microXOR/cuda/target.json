{
    "app": "microxor",
    "model": "cuda",
    "path": "targets/microXOR/cuda/repo",
    "dependencies": ["cuda"],
    "build_commands_debug": "make clean ;; make -B CUDA_ARCH=sm_80 DEBUG=yes",
    "build_commands_perf": "make clean ;; make -B CUDA_ARCH=sm_80",
    "build_timeout": 30,
    "exe_file": "microXOR.exe",
    "debug_type": "match",
    "run_commands_debug": [
        "./microXOR.exe 4 2",
        "./microXOR.exe 1024 32",
        "./microXOR.exe 4096 16"
    ],
    "debug_outputs": [
        "Validation passed.",
        "Validation passed.",
        "Validation passed."
    ],
    "run_commands_perf": [
        "./microXOR.exe 4096 16"
    ],
    "perf_outputs": [
        "Validation passed."
    ],
    "run_timeout": 120,
    "ex_build_cmd": "make SM_VERSION=80",
    "ex_build_desc": "a system with an NVIDIA GPU with compute capability 80",
    "build_filename": "Makefile",
    "ex_run_cmd": "./microXOR.exe 1024 32",
    "ex_run_desc": "a 1024 by 1024 input matrix and a kernel with 32 times 32 threads per block",
    "main_filename": "src/main.cu",
    "filename_desc": "C++"
}
